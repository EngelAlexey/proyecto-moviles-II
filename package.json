{
  "name": "dado-triple",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:no-mobile": "turbo run dev --filter=@dado-triple/web --filter=@dado-triple/server",
    "dev:mobile": "pnpm --filter @dado-triple/mobile start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "deploy:web": "cd apps/web && vercel --prod",
    "mobile:build:android:preview": "pnpm --filter @dado-triple/mobile build:android:preview",
    "mobile:build:android:production": "pnpm --filter @dado-triple/mobile build:android:production",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "husky": "^9.1.7",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}

