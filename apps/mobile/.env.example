# Transporte de tiempo real para la app mobile.
# Valores soportados: socket.io | websocket
EXPO_PUBLIC_REALTIME_TRANSPORT=socket.io

# URL del servidor de tiempo real.
# En Android emulator, localhost del host suele mapearse como 10.0.2.2
# Socket.IO actual:
EXPO_PUBLIC_REALTIME_URL=http://10.0.2.2:4000

# Si luego migran a Rust con WebSocket nativo, usen por ejemplo:
# EXPO_PUBLIC_REALTIME_TRANSPORT=websocket
# EXPO_PUBLIC_REALTIME_URL=ws://10.0.2.2:5000
