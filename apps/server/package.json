{
  "name": "@dado-triple/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm --filter @dado-triple/db prisma:generate && tsc",
    "dev": "pnpm --filter @dado-triple/db prisma:generate && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prisma:generate": "pnpm --filter @dado-triple/db prisma:generate",
    "test:db": "tsx src/testConnection.ts"
  },
  "dependencies": {
    "@dado-triple/db": "workspace:*",
    "@dado-triple/game-logic": "workspace:*",
    "@dado-triple/shared-types": "workspace:*",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "ioredis": "latest",
    "@upstash/redis": "latest",
    "mongoose": "latest",
    "socket.io": "latest"
  },
  "devDependencies": {
    "@dado-triple/typescript-config": "workspace:*",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jest": "^30.0.0",
    "@types/node": "latest",
    "jest": "^30.3.0",
    "nodemon": "latest",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.4.6",
    "ts-node": "latest",
    "tsx": "^4.21.0",
    "typescript": "latest"
  }
}
