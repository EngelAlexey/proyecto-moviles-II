# Puerto del backend Node
PORT=4000

# MongoDB Atlas Connection String
# Reemplaza <user>, <password>, <cluster> y <database> con tus credenciales
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority"

# Redis opcional para estado en tiempo real.
# Puedes usar REDIS_URL o las variables de Upstash.
# REDIS_URL="redis://localhost:6379"
# UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"

# Nota:
# El tiempo real de Web y Mobile se configura en sus propios .env
# porque esas apps necesitan leer sus variables en su propio runtime.
