# La app web ya no depende de variables de entorno para el realtime.
# El cliente observer usa WebSocket nativo fijo contra:
# ws://18.218.158.112:5000
#
# El dashboard administrativo sí consulta MongoDB desde Server Components.
# Configura la misma cadena de conexión usada por el backend Node.
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority"
