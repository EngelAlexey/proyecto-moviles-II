generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model PlayerModel {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  username   String   @unique
  totalScore Int      @default(0)
  createdAt  DateTime @default(now())

  // Relaciones manuales (Flat) para evitar transacciones en Atlas M0
  sessionIds String[] @db.ObjectId

  @@map("players")
}

model GameSessionModel {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  status    String    // "waiting" | "pairing" | "playing" | "finished"
  startTime DateTime  @default(now())
  endTime   DateTime?

  // Relaciones manuales (Flat) para evitar transacciones en Atlas M0
  playerIds String[] @db.ObjectId

  @@map("game_sessions")
}

model MovementModel {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  // Relaciones manuales (Flat) para evitar transacciones en Atlas M0
  sessionId   String   @db.ObjectId
  playerId    String   @db.ObjectId

  diceValues  Int[]    // Tupla exacta de los 3 dados [d1, d2, d3]
  comboType   String   // "triple" | "par" | "nada"
  scoreEarned Int
  timestamp   DateTime @default(now())

  @@map("movements")
}

model TestRecord {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  message     String
  author      String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("test_records")
}
