# Transporte de tiempo real para la app web.
# Valores soportados: socket.io | websocket
NEXT_PUBLIC_REALTIME_TRANSPORT=socket.io

# URL del servidor de tiempo real.
# Socket.IO actual:
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# Si luego migran a Rust con WebSocket nativo, usen por ejemplo:
# NEXT_PUBLIC_REALTIME_TRANSPORT=websocket
# NEXT_PUBLIC_REALTIME_URL=ws://localhost:5000
